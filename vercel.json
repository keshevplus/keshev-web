{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm run build && mkdir -p dist",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/admin", "destination": "https://admin.keshevplus.com", "permanent": false },
    { "source": "/admin/:path*", "destination": "https://admin.keshevplus.com/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://www.keshevplus.com/api/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
