# Client .env.example
# All variables must start with VITE_ to be exposed in Vite/React.
# Do NOT put secrets here - this file is committed, and anything VITE_ is
# readable in the browser bundle. Copy this to .env (gitignored) and fill
# in real values locally; set real values in the Vercel project settings
# for deployed environments.

VITE_NODE_ENV=production

# KeshevPlus platform app/API (backend, CMS, forms, scheduling, chat, DB)
VITE_PLATFORM_URL=https://www.keshevplus.com
VITE_API_BASE_URL=https://www.keshevplus.com
VITE_BASE_URL=https://www.keshevplus.co.il

# Admin dashboard lives separately; the frontend links/redirects to it.
VITE_ADMIN_DASHBOARD_URL=https://admin.keshevplus.com

# EmailJS (client-side contact form fallback, if still used)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# Add more VITE_ variables as needed for the client app.
# Feature flags, e.g.:
# VITE_FEATURE_X_ENABLED=true
